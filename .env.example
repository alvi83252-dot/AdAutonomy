# =============================================================================
# AdAutonomy Environment Configuration
# Copy this file to .env.local (development) or .env (production)
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AdAutonomy

# Demo mode: auto-approve agent actions but log everything
DEMO_MODE=true

# -----------------------------------------------------------------------------
# LLM Provider (openai | mock)
# Use "mock" for fully offline operation with no API keys
# -----------------------------------------------------------------------------
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Supabase (local or cloud)
# For local: run `npx supabase start` or use docker-compose
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# SQLite fallback when Supabase is unavailable
USE_SQLITE_FALLBACK=true
SQLITE_DB_PATH=./data/adautonomy.db

# -----------------------------------------------------------------------------
# PayPal Sandbox API
# Get credentials at https://developer.paypal.com/dashboard/applications/sandbox
# -----------------------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX_MODE=true
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# -----------------------------------------------------------------------------
# Wassist — WhatsApp AI agents (powers the FeedbackAgent customer-feedback line)
# Create a key at https://wassist.app -> Settings -> API Keys
# Leave WASSIST_API_KEY blank to run fully offline (FeedbackAgent uses mock data).
# Server-only secret — never expose with a NEXT_PUBLIC_ prefix.
# WASSIST_FEEDBACK_ENABLED (under "Sponsor integrations" below) gates the call.
# -----------------------------------------------------------------------------
WASSIST_API_KEY=
WASSIST_API_BASE=https://backend.wassist.app/api/v1

# -----------------------------------------------------------------------------
# Vercel Eve (offline agent runtime)
# -----------------------------------------------------------------------------
EVE_OFFLINE_MODE=true
EVE_AGENT_PATH=./eve

# -----------------------------------------------------------------------------
# Sponsor integrations (simulated locally)
# -----------------------------------------------------------------------------
MODAL_SIMULATION_ENABLED=true
SEAPOINT_WORKFLOW_ENABLED=true
MANUS_ORCHESTRATION_ENABLED=true
ELYOS_SAFETY_ENABLED=true
WASSIST_FEEDBACK_ENABLED=true
SEEDCAMP_INVESTOR_ENABLED=true
BLUEWIRE_FINANCE_ENABLED=true
IO_DEPLOYMENT_ENABLED=true
DRAGONFLY_SCORING_ENABLED=true

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
ENABLE_PAYPAL_MOCK_FALLBACK=true
ENABLE_AGENT_LOGGING=true
ENABLE_ICS_EXPORT=true
ENABLE_PDF_EXPORT=true

# -----------------------------------------------------------------------------
# Social Media APIs (add later for live auto-posting)
# -----------------------------------------------------------------------------
META_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=
YOUTUBE_API_KEY=
ENABLE_SOCIAL_AUTO_PUBLISH=true

# -----------------------------------------------------------------------------
# Personal Assistant (uses OPENAI_API_KEY above when LLM_PROVIDER=openai)
# -----------------------------------------------------------------------------
ASSISTANT_ENABLED=true

# -----------------------------------------------------------------------------
# Video background music (MP3 in public/audio/)
# Replace public/audio/background.mp3 with your own file
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VIDEO_BACKGROUND_AUDIO=/audio/background.mp3
